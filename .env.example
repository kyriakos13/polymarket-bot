# Αντέγραψε αυτό το αρχείο σε .env και συμπλήρωσε τα δικά σου.
# ΤΟ .env ΔΕΝ ΤΟ ΜΟΙΡΑΖΕΣΑΙ ΠΟΤΕ ΚΑΙ ΔΕΝ ΤΟ ΑΝΕΒΑΖΕΙΣ ΠΟΥΘΕΝΑ.

# Private key: Polymarket -> προφίλ -> Settings -> Export Private Key
PRIVATE_KEY=

# Η διεύθυνση του Polymarket wallet σου (φαίνεται στο προφίλ σου, 0x...)
FUNDER_ADDRESS=

# 1 = λογαριασμός με email/Google login (το συνηθισμένο), 2 = σύνδεση με MetaMask κλπ.
SIGNATURE_TYPE=1

# true = ΔΕΝ βάζει πραγματικά orders, μόνο τυπώνει τι θα έκανε. Ξεκίνα ΠΑΝΤΑ με true.
DRY_RUN=true

# Ρυθμίσεις copy trading
COPY_SHARES=5
MAX_COPY_PRICE_CENTS=10
POLL_SECONDS=5
